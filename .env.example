# Copy this file to `.env` in the project root and fill in values.
# `.env` is gitignored — never commit real keys.

# --- OpenAI (weather forecast primary) ---
# Preferred: set here. Alternative: one-line file `openai_api_key.txt` in project root (gitignored).
OPENAI_API_KEY=

# --- AccuWeather (weather fallback) ---
# Optional. Get a free key at https://developer.accuweather.com/
# Alternative: one-line file `accuweather_api_key.txt` in project root (gitignored).
ACCUWEATHER_API_KEY=

# --- Server ---
# ARECO_PORT=8765

# --- Settlement zip extraction (Billing panel) ---
# Master zip from the other app = no password.
# Passwords apply to: (1) inner _ARECO / _ARECOSS bundle zips, (2) each daily ARECO_Energy_* / ARECOSS_Energy_* zip.
# Same order as Excel Sheet1 B2 / B3 (try 1, then 2, then unencrypted). No trailing spaces. Restart Flask after edits.
ARECO_SETTLEMENT_ZIP_PASSWORD1=
ARECO_SETTLEMENT_ZIP_PASSWORD2=
